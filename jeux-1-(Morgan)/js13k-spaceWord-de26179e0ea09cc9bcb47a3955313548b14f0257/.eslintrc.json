{
    "env": {
        "browser": true,
        "es2021": true,
        "node": true,
        "jest": true
    },
    "extends": [
        "google"
    ],
    "parserOptions": {
        "ecmaVersion": 12
    },
    "rules": {
        "require-jsdoc": "off",
        "valid-jsdoc": "off",
        "max-len": "off",
        "no-unused-vars": ["error", { "varsIgnorePattern": "^(beginGame|sike|restartStateGame)$" }]
    },
    "ignorePatterns": ["dist/", "node_modules/", "*.min.js"],
    "overrides": [
        {
            "files": ["**/script.js"],
            "rules": {
                "no-unused-vars": "off",
                "no-undef": "off"
            }
        },
        {
            "files": ["cypress.config.js"],
            "rules": {
                "no-unused-vars": "off"
            }
        }
    ]
}