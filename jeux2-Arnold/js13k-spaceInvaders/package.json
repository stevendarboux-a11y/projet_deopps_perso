{
  "scripts": {
    "start": "parcel ./src/index.html",
    "build": "rm -rf build && parcel build -d build --public-url ./ --no-source-maps ./src/index.html",
    "zip": "rm -f bundle.zip && cd build && bestzip ../bundle.zip *",
    "bundle": "npm run build && npm run zip",
    "test": "jest",
    "lint": "eslint 'src/**/*.ts'"
  },
  "devDependencies": {
    "bestzip": "^2.2.0",
    "parcel-bundler": "^1.12.5",
    "sass": "^1.39.0",
    "typescript": "^4.4.2",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "eslint": "^8.0.0",
    "eslint-config-google": "^0.14.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  },
  "overrides": {
    "braces": "^3.0.3",
    "elliptic": "^6.6.1",
    "form-data": "^2.5.4",
    "node-forge": "^1.3.0",
    "postcss": "^8.4.31",
    "nth-check": "^2.1.1",
    "qs": "^6.14.1",
    "tough-cookie": "^4.1.3",
    "terser": "^4.8.1"
  }
}
